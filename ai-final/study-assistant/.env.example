# ─────────────────────────────────────────────────────────────────────────────
# Personal Study Assistant — environment variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Default mode at startup ─────────────────────────────────────────────────────
# Set to "offline" to start in local model mode without Azure auth.
# Can be switched at runtime from the UI toggle.
DEFAULT_MODE=online

# ── Online mode — Foundry-hosted agent ───────────────────────────────────────────
# The base URL for your Foundry project, found in Foundry Toolkit after
# creating the agent. Looks like:
#   https://<resource>.services.ai.azure.com/api/projects/<project-name>/
# The agent_client strips any trailing /responses automatically.
AGENT_ENDPOINT=https://<your-foundry-resource>.services.ai.azure.com/api/projects/<your-project-name>/

# DefaultAzureCredential is used automatically — no key needed here.
# Make sure you are logged in via one of:
#   az login                   (Azure CLI — recommended for local dev)
#   VS Code Azure account       (Azure Account extension)
#   Managed Identity            (when deployed to Azure)

# ── Offline mode — local OpenAI-compatible model ──────────────────────────────
# Supports any local server that exposes an OpenAI-compatible /v1 endpoint:
#   Ollama    — https://ollama.com          (default port 11434)
#   LM Studio — https://lmstudio.ai        (default port 1234)
#
# Base URL of the local server
OFFLINE_ENDPOINT=http://localhost:11434/v1
#
# Model name as it appears in the local server (e.g. ollama list)
# IMPORTANT: must be a model that supports tool/function calling.
# Supported: llama3.1, llama3.2, mistral, qwen2.5, gemma3
# NOT supported: llama3 (3.0), phi3-mini
OFFLINE_MODEL=llama3.2
#
# API key — Ollama ignores the value but the OpenAI SDK requires a non-empty string
OFFLINE_API_KEY=ollama

# ── Optional: Flask dev settings (remove or set to 0 in production) ───────────
# FLASK_DEBUG=1
# FLASK_RUN_PORT=5000
