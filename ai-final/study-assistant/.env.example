# ─────────────────────────────────────────────────────────────────────────────
# Personal Study Assistant — environment variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Foundry agent endpoint ────────────────────────────────────────────────────
# The base URL for your Foundry project, found in Foundry Toolkit after
# creating the agent. Looks like:
#   https://<resource>.services.ai.azure.com/api/projects/<project-name>/
# The agent_client strips any trailing /responses automatically.
AGENT_ENDPOINT=https://<your-foundry-resource>.services.ai.azure.com/api/projects/<your-project-name>/

# ── Azure authentication ───────────────────────────────────────────────────────
# DefaultAzureCredential is used automatically — no key needed here.
# Make sure you are logged in via one of:
#   az login                   (Azure CLI — recommended for local dev)
#   VS Code Azure account       (Azure Account extension)
#   Managed Identity            (when deployed to Azure)

# ── Optional: Flask dev settings (remove or set to 0 in production) ───────────
# FLASK_DEBUG=1
# FLASK_RUN_PORT=5000
